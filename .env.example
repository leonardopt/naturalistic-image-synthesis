# Set manually before starting the pipeline
BASE_DIR=/path/to/your/output/directory
# e.g. BASE_DIR=/data/stimuli_output
# Optional manual input after stage 02a:
#   place excluded_images.csv inside BASE_DIR/generation_YYYYMMDD_HHMMSS/
#   if you want pipe_02b_exclude_images.py to move flagged anchor images.

# The following variables are written automatically by each pipeline stage
STIM_SET_NAME=generation_YYYYMMDD_HHMMSS
DESIGN_FILE=stim_design_YYYYMMDD_HHMMSS.parquet
SELECTED_PAIRS_FILE=selected_pairs_for_interpolation_TIMESTAMP_final_selection.csv
INTERPOL_DIR_NAME=interpolations_YYYYMMDD_HHMMSS
